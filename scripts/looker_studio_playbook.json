  "procedures": {
    "create_blank_report": {
      "steps": [
        "Navigate to https://lookerstudio.google.com/navigation/reporting and create a new blank report."
      ]
    },
    "connect_bigquery": {
      "params": ["project_id", "dataset", "table"],
      "steps": [
        "Add data to report > Click 'BigQuery' > project '{project_id}' > dataset '{dataset}' > table '{table}' > Click 'Add'"
      ]
    },
    "enable_responsive_layout": {
      "steps": [
        "Enable Responsive Layout."
      ]
    },
     "close_data_panel":{
      "steps":[
        "Click at the panel toggle 'Data' at the right of the webpage."
      ]
     },

    "add_first_chart_to_section": {
      "params": ["chart_type"],
      "steps": [
        "Click at the 'Add Chart' placeholder and select '{chart_type}'. Then wait 2 sec."
      ]
    },
    "add_another_chart_to_section": {
      "params": ["chart_type"],
      "steps": [
        "Find the visualization you just configured in the DOM tree (its [N] index). Call hover_and_click_revealed with the same index and button_aria_label='Add a chart', then select '{chart_type}'. Then wait 2 sec."
      ]
    },
    "add_first_control_to_section": {
      "params": ["chart_type"],
      "steps": [
        "Click the 'Add control' placeholder and select '{chart_type}'. Then wait 2 sec."
      ]
    },
    "add_another_control_to_section": {
      "params": ["chart_type"],
      "steps": [
        "Find the visualization you just configured in the DOM tree (its [N] index). Call hover_and_click_revealed with the same index and button_aria_label='Add a control', then select '{chart_type}'. Then wait 2 sec."
      ]
    },
    "add_new_section": {
      "params": ["chart_type"],
      "steps": [
        "Click 'Insert' in the toolbar and select '{chart_type}'. Then wait 2 sec."
      ]
    },
    "add_text_to_section": {
      "params": ["text_content"],
      "steps": [
        "Click 'Insert' in the toolbar and select 'Text'.",
        "Type '{text_content}' in the text box that appears."
      ]
    },
    "set_section_style_stretch": {
      "steps": [
        "Find the visualization you just configured in the DOM tree (its [N] index). Call hover_and_click_revealed with the same index and button_aria_label='Open style menu', wait for 2 seconds , and then click 'stretch' in that style menu."
      ]
    },

    "set_dimension": {
      "params": ["dimension_name"],
      "steps": [
        "In the Setup tab, change the default dimension to '{dimension_name}'."
      ]
    },
    "add_dimension": {
      "params": ["dimension_name"],
      "steps": [
        "In the Setup tab, click 'Add dimension' and click '{dimension_name}'."
      ]
    },
    "set_metric": {
      "params": ["metric_name"],
      "steps": [
        "In the Setup tab, change the default metric to '{metric_name}'."
      ]
    },
    "set_metric_with_aggregation": {
      "params": ["metric_name", "aggregation_type"],
      "steps": [
        "In the Setup tab, change the default metric to '{metric_name}', then change its aggregation to '{aggregation_type}'. After that sendkey: Escape"
      ]
    },
    "add_metric": {
      "params": ["metric_name"],
      "steps": [
        "In the Setup tab, click 'Add metric' and click '{metric_name}'."
      ]
    },
    "add_metric_with_aggregation": {
      "params": ["metric_name", "aggregation_type"],
      "steps": [
        "In the Setup tab, click 'Add metric' and click '{metric_name}', then change its aggregation to '{aggregation_type}'. After that sendkey: Escape"
      ]
    },
    "set_sort": {
      "params": ["sort_field", "sort_order"],
      "steps": [
        "In the Setup tab, set the sort field to '{sort_field}' and sort order to '{sort_order}'."
      ]
    },
    "set_row_limit": {
      "params": ["row_limit"],
      "steps": [
        "In the Setup tab, set row limit to {row_limit}."
      ]
    },
    "toggle_cross_filtering": {
      "steps": [
        "In the Setup tab, enable the 'Cross-filtering' toggle (aria-label='Cross-filtering')."
      ]
    },
    "add_chart_filter": {
      "params": ["filter_type", "field_name", "condition", "value"],
      "steps": [
        "In the Setup tab, click 'Add a filter' to open the filter dialog.",
        "Set type to {filter_type}, field to '{field_name}', condition to '{condition}', value to '{value}'. Then click 'Save'."
      ]
    },
    "add_chart_filter_between": {
      "params": ["filter_type", "field_name", "value_start", "value_end"],
      "steps": [
        "In the Setup tab, click 'Add a filter' to open the filter dialog.",
        "Set type to {filter_type}, field to '{field_name}', condition to 'Between (>= && <=)', first value to '{value_start}', second value to '{value_end}'. Then click 'Save'."
      ]
    },
    "add_calculated_field": {
      "params": ["field_name", "formula"],
      "steps": [
        "In the Data panel on the right, click 'Add a field' (aria-label='Add a field'). Then click 'Add a calculated field'.",
        "Name the field '{field_name}'. Click the formula text box, clear it, and enter: {formula}",
        "Click 'Save'. Then click 'Done'."
      ]
    },

    "style_set_title": {
      "params": ["title_text"],
      "steps": [
        "Enable the 'Show title' toggle if off, then set the chart title to '{title_text}'."
      ]
    },
    "style_set_color": {
      "params": ["color_value"],
      "steps": [
        "Set the series color to '{color_value}'."
      ]
    },
    "style_set_font_size": {
      "params": ["font_size"],
      "steps": [
        "Set the font size to '{font_size}'."
      ]
    },
    "style_set_font_color": {
      "params": ["color_value"],
      "steps": [
        "Set the font color to '{color_value}'."
      ]
    },
    "style_toggle_x_axis_title": {
      "steps": [
        "Enable 'Show axes' if off. Then enable the FIRST 'Show axis title' toggle (X-axis) if off."
      ]
    },
    "style_toggle_y_axis_title": {
      "steps": [
        "Enable 'Show axes' if off. Then enable the SECOND 'Show axis title' toggle (Y-axis) if off."
      ]
    },
    "style_toggle_shadow": {
      "steps": [
        "Enable 'Add border shadow' if off."
      ]
    },
    "style_set_legend_position": {
      "params": ["position"],
      "steps": [
        "Set the legend position to '{position}'."
      ]
    },
    "style_toggle_data_labels": {
      "steps": [
        "Enable 'Show data labels' if off."
      ]
    },
    "style_toggle_compact_numbers": {
      "steps": [
        "Enable 'Compact numbers' if off."
      ]
    },
    "style_set_background_color": {
      "params": ["color_value"],
      "steps": [
        "Set the background color to '{color_value}'."
      ]
    },
    "others": {
      "params": ["others"],
      "steps": [
        "{others}"
      ]
    },
    "set_metric_aggregation": {
      "params": ["metric_name", "aggregation_type"],
      "steps": [
        "In the Setup tab, change the aggregation of '{metric_name}' to '{aggregation_type}'.After that sendkey: Escape"
      ]
    },
    "set_report_title": {
      "params": ["report_title"],
      "steps": [
        "Double-click the report title on the canvas, and type '{report_title}'."
      ]
    },
    "set_editor_title": {
      "params": ["report_title"],
      "steps": [
        "Click the report name at the top of the editor and rename it to '{report_title}'."
      ]
    }
  }
}
