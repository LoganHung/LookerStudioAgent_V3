    },
    {
      "field_name": "Device_Growth_Rate",
      "formula": "(SUM(IF(category_order = 7, Total_Device_Count, 0)) - SUM(IF(category_order = 1, Total_Device_Count, 0))) / SUM(IF(category_order = 1, Total_Device_Count, 0))"
    }
